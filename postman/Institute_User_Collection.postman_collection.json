              "host": ["localhost"],
              "port": "6008",
              "path": ["api", "categories", "products"]
            },
            "description": "Returns ALL product categories (both institute and normal)."
          }
        },
        {
          "name": "Get All Institute Main Categories",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "var cats = json.data || [];", "var mains = cats.filter(function(c){ return c.name.indexOf('/') === -1; });", "if(mains.length > 0) pm.collectionVariables.set('category_id', mains[0].id);", "if(cats.length > 0 && !pm.collectionVariables.get('category_id')) pm.collectionVariables.set('category_id', cats[0].id);"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:6008/api/categories/products?isInstituteCategory=true",
              "protocol": "http",
              "host": ["localhost"],
              "port": "6008",
              "path": ["api", "categories", "products"],
              "query": [{ "key": "isInstituteCategory", "value": "true" }]
            },
            "description": "Get only government/institute categories. Main categories have no '/' in name. Auto-saves first main category ID."
          }
        },
        {
          "name": "Get All Institute Sub-Categories",
          "request": {
