            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:6008/api/categories/products?isInstituteCategory=true",
              "protocol": "http",
              "host": ["localhost"],
              "port": "6008",
              "path": ["api", "categories", "products"],
              "query": [{ "key": "isInstituteCategory", "value": "true" }]
            },
            "description": "Returns all institute categories. Sub-categories have '/' separator in name (e.g. 'ParentName / SubName'). Filter in client by checking name.includes('/')."
          }
