        {
          "name": "Get All Institute Products",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if(json.data && json.data.length > 0) pm.collectionVariables.set('product_id', json.data[0].id);", "pm.test('List institute products 200', function () { pm.response.to.have.status(200); });", "pm.test('Response has institute products for seeded DB', function () { pm.expect(json.success).to.be.true; pm.expect(json.data).to.be.an('array'); pm.expect(json.data.length, 'Run: npm run prisma:seed:institute (backend)').to.be.above(0); });", "pm.test('product_id variable set', function () { pm.expect(pm.collectionVariables.get('product_id')).to.match(/^[0-9a-f-]{36}$/i); });"] } }],
