# Copy to .env and adjust. Never commit real secrets.

NODE_ENV=development
DATABASE_URL="mysql://user:pass@localhost:3306/studify"

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_EXPIRES_IN=7d

# Production frontend (Studify web app)
FRONTEND_URL=https://studify.developteam.site/
# Optional CORS override (comma-separated)
# CORS_ORIGIN=https://studify.developteam.site,http://localhost:5173

API_URL=http://localhost:6008
PORT=6008

# Google Gemini (AI Chatbot)
GEMINI_API_KEY=
GEMINI_PROJECT_ID=

# OpenAI (legacy — no longer used)
# OPENAI_API_KEY=
